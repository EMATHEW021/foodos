// FoodOS Database Schema
// Restaurant Management SaaS - Multi-tenant with RLS

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// TENANT (Restaurant)
// ============================================
model Tenant {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String   @db.VarChar(255)
  slug               String   @unique @db.VarChar(100)
  phone              String   @db.VarChar(20)
  email              String?  @db.VarChar(255)
  address            String?  @db.Text
  city               String   @default("Dar es Salaam") @db.VarChar(100)
  timezone           String   @default("Africa/Dar_es_Salaam") @db.VarChar(50)
  currency           String   @default("TZS") @db.VarChar(10)
  subscriptionPlan   SubscriptionPlan   @default(free) @map("subscription_plan")
  subscriptionStatus SubscriptionStatus @default(trial) @map("subscription_status")
  trialEndsAt        DateTime? @map("trial_ends_at")
  logoUrl            String?  @map("logo_url") @db.Text
  approvalStatus     TenantStatus   @default(pending) @map("approval_status")
  approvedAt         DateTime?      @map("approved_at")
  rejectionReason    String?        @map("rejection_reason") @db.Text
  maxUsers           Int            @default(3) @map("max_users")
  // KYC fields
  kycStatus          KycStatus      @default(not_submitted) @map("kyc_status")
  nidaNumber         String?        @map("nida_number") @db.VarChar(50)
  shopPhotoUrl       String?        @map("shop_photo_url") @db.Text
  shopAddress        String?        @map("shop_address") @db.Text
  shopType           String?        @map("shop_type") @db.VarChar(100)
  kycSubmittedAt     DateTime?      @map("kyc_submitted_at")
  kycApprovedAt      DateTime?      @map("kyc_approved_at")
  kycRejectionReason String?        @map("kyc_rejection_reason") @db.Text
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Relations
  users              User[]
  menuCategories     MenuCategory[]
  menuItems          MenuItem[]
  ingredients        Ingredient[]
  recipes            Recipe[]
  inventoryMovements InventoryMovement[]
  orders             Order[]
  orderItems         OrderItem[]
  expenses           Expense[]
  dailySummaries     DailySummary[]

  @@map("tenants")
}

enum SubscriptionPlan {
  free
  starter
  professional
  business
  enterprise
}

enum SubscriptionStatus {
  active
  trial
  past_due
  cancelled
}

enum TenantStatus {
  pending
  approved
  rejected
  suspended
}

enum KycStatus {
  not_submitted
  submitted
  approved
  rejected
}

// ============================================
// USER (Staff)
// ============================================
model User {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  authId    String?  @unique @map("auth_id") // Supabase Auth UID
  name      String   @db.VarChar(255)
  phone     String   @db.VarChar(20)
  email     String?  @db.VarChar(255)
  role      UserRole @default(cashier)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant               Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  submittedMovements   InventoryMovement[] @relation("SubmittedBy")
  approvedMovements    InventoryMovement[] @relation("ApprovedBy")
  cashierOrders        Order[]             @relation("CashierOrders")
  submittedExpenses    Expense[]           @relation("SubmittedExpenses")
  approvedExpenses     Expense[]           @relation("ApprovedExpenses")

  @@index([tenantId])
  @@map("users")
}

enum UserRole {
  owner
  manager
  cashier
  super_admin
}

// ============================================
// MENU CATEGORY
// ============================================
model MenuCategory {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String   @db.VarChar(100)
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  menuItems MenuItem[]

  @@index([tenantId])
  @@map("menu_categories")
}

// ============================================
// MENU ITEM (Dish/Product)
// ============================================
model MenuItem {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  categoryId  String   @map("category_id") @db.Uuid
  name        String   @db.VarChar(255)
  description String?  @db.Text
  price       Decimal  @db.Decimal(12, 2)
  imageUrl    String?  @map("image_url") @db.Text
  isAvailable Boolean  @default(true) @map("is_available")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category   MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  recipes    Recipe[]
  orderItems OrderItem[]

  @@index([tenantId])
  @@index([categoryId])
  @@map("menu_items")
}

// ============================================
// INGREDIENT (Raw Material)
// ============================================
model Ingredient {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  name         String   @db.VarChar(255)
  unit         String   @db.VarChar(50) // kg, liter, piece, bunch
  currentStock Decimal  @default(0) @map("current_stock") @db.Decimal(12, 3)
  minStock     Decimal  @default(0) @map("min_stock") @db.Decimal(12, 3)
  costPerUnit  Decimal  @default(0) @map("cost_per_unit") @db.Decimal(12, 2)
  category     String?  @db.VarChar(100) // Proteins, Vegetables, Grains, Spices
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recipes    Recipe[]
  movements  InventoryMovement[]

  @@index([tenantId])
  @@map("ingredients")
}

// ============================================
// RECIPE (Links Menu Item to Ingredients)
// ============================================
model Recipe {
  id             String  @id @default(uuid()) @db.Uuid
  tenantId       String  @map("tenant_id") @db.Uuid
  menuItemId     String  @map("menu_item_id") @db.Uuid
  ingredientId   String  @map("ingredient_id") @db.Uuid
  quantityNeeded Decimal @map("quantity_needed") @db.Decimal(10, 3)

  // Relations
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  menuItem   MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, ingredientId])
  @@index([tenantId])
  @@map("recipes")
}

// ============================================
// INVENTORY MOVEMENT (Stock In/Out History)
// ============================================
model InventoryMovement {
  id              String         @id @default(uuid()) @db.Uuid
  tenantId        String         @map("tenant_id") @db.Uuid
  ingredientId    String         @map("ingredient_id") @db.Uuid
  type            MovementType
  quantity        Decimal        @db.Decimal(12, 3)
  unitCost        Decimal        @default(0) @map("unit_cost") @db.Decimal(12, 2)
  totalCost       Decimal        @default(0) @map("total_cost") @db.Decimal(12, 2)
  reason          String?        @db.Text
  supplier        String?        @db.VarChar(255)
  orderId         String?        @map("order_id") @db.Uuid
  submittedById   String         @map("submitted_by") @db.Uuid
  approvedById    String?        @map("approved_by") @db.Uuid
  approvalStatus  ApprovalStatus @default(pending) @map("approval_status")
  rejectionReason String?        @map("rejection_reason") @db.Text
  createdAt       DateTime       @default(now()) @map("created_at")
  approvedAt      DateTime?      @map("approved_at")

  // Relations
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ingredient  Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  order       Order?     @relation(fields: [orderId], references: [id])
  submittedBy User       @relation("SubmittedBy", fields: [submittedById], references: [id])
  approvedBy  User?      @relation("ApprovedBy", fields: [approvedById], references: [id])

  @@index([tenantId])
  @@index([ingredientId])
  @@index([approvalStatus])
  @@map("inventory_movements")
}

enum MovementType {
  IN         // Stock received from supplier
  OUT        // Manual stock out (wastage, personal use)
  ORDER      // Auto-deducted from order
  ADJUSTMENT // Stock count correction
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

// ============================================
// ORDER
// ============================================
model Order {
  id               String        @id @default(uuid()) @db.Uuid
  tenantId         String        @map("tenant_id") @db.Uuid
  orderNumber      Int           @default(autoincrement()) @map("order_number")
  status           OrderStatus   @default(pending)
  subtotal         Decimal       @default(0) @db.Decimal(12, 2)
  discount         Decimal       @default(0) @db.Decimal(12, 2)
  total            Decimal       @default(0) @db.Decimal(12, 2)
  paymentMethod    PaymentMethod? @map("payment_method")
  paymentStatus    PaymentStatus @default(pending) @map("payment_status")
  paymentReference String?       @map("payment_reference") @db.VarChar(255)
  customerPhone    String?       @map("customer_phone") @db.VarChar(20)
  tableNumber      String?       @map("table_number") @db.VarChar(20)
  notes            String?       @db.Text
  cashierId        String        @map("cashier_id") @db.Uuid
  cogsTotal        Decimal       @default(0) @map("cogs_total") @db.Decimal(12, 2)
  createdAt        DateTime      @default(now()) @map("created_at")
  completedAt      DateTime?     @map("completed_at")

  // Relations
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cashier            User                @relation("CashierOrders", fields: [cashierId], references: [id])
  orderItems         OrderItem[]
  inventoryMovements InventoryMovement[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("orders")
}

enum OrderStatus {
  pending
  confirmed
  preparing
  ready
  completed
  cancelled
}

enum PaymentMethod {
  cash
  mpesa
  tigopesa
  airtelmoney
  halopesa
  card
  split
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

// ============================================
// ORDER ITEM (Line Items)
// ============================================
model OrderItem {
  id         String  @id @default(uuid()) @db.Uuid
  tenantId   String  @map("tenant_id") @db.Uuid
  orderId    String  @map("order_id") @db.Uuid
  menuItemId String  @map("menu_item_id") @db.Uuid
  quantity   Int
  unitPrice  Decimal @map("unit_price") @db.Decimal(12, 2)
  totalPrice Decimal @map("total_price") @db.Decimal(12, 2)
  unitCogs   Decimal @default(0) @map("unit_cogs") @db.Decimal(12, 2)
  notes      String? @db.Text

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([tenantId])
  @@index([orderId])
  @@map("order_items")
}

// ============================================
// EXPENSE
// ============================================
model Expense {
  id              String         @id @default(uuid()) @db.Uuid
  tenantId        String         @map("tenant_id") @db.Uuid
  category        String         @db.VarChar(100) // Rent, Gas, Packaging, Transport
  amount          Decimal        @db.Decimal(12, 2)
  description     String?        @db.Text
  date            DateTime       @db.Date
  receiptUrl      String?        @map("receipt_url") @db.Text
  submittedById   String         @map("submitted_by") @db.Uuid
  approvedById    String?        @map("approved_by") @db.Uuid
  approvalStatus  ApprovalStatus @default(pending) @map("approval_status")
  createdAt       DateTime       @default(now()) @map("created_at")

  // Relations
  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  submittedBy User   @relation("SubmittedExpenses", fields: [submittedById], references: [id])
  approvedBy  User?  @relation("ApprovedExpenses", fields: [approvedById], references: [id])

  @@index([tenantId])
  @@index([tenantId, date])
  @@map("expenses")
}

// ============================================
// DAILY SUMMARY (Pre-aggregated Reports)
// ============================================
model DailySummary {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  date           DateTime @db.Date
  totalRevenue   Decimal  @default(0) @map("total_revenue") @db.Decimal(12, 2)
  totalCogs      Decimal  @default(0) @map("total_cogs") @db.Decimal(12, 2)
  totalExpenses  Decimal  @default(0) @map("total_expenses") @db.Decimal(12, 2)
  netProfit      Decimal  @default(0) @map("net_profit") @db.Decimal(12, 2)
  orderCount     Int      @default(0) @map("order_count")
  cashRevenue    Decimal  @default(0) @map("cash_revenue") @db.Decimal(12, 2)
  mobileRevenue  Decimal  @default(0) @map("mobile_revenue") @db.Decimal(12, 2)

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date])
  @@index([tenantId])
  @@map("daily_summaries")
}

// ============================================
// USER ACTION (Smart Card Ordering)
// ============================================
model UserAction {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  action    String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([tenantId])
  @@map("user_actions")
}
